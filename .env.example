# ── uberserver environment config ─────────────────────────────────────────────
# Copy this to .env and fill in your values before running docker-compose up.
# Never commit .env to source control.

# MariaDB credentials
DB_ROOT_PASSWORD=change_me_root
DB_NAME=uberserver
DB_USER=uberserver
DB_PASSWORD=change_me_strong_password

# Ports exposed on the host (change if you have conflicts)
LOBBY_PORT=8200
NAT_PORT=8201

# MaxMind GeoLite2 licence key (free signup at https://www.maxmind.com/en/geolite2/signup)
# Without this, all players will show country code '??'
MAXMIND_LICENSE_KEY=

# Optional extra arguments passed directly to server.py, e.g.:
# EXTRA_ARGS=--no-censor
EXTRA_ARGS=
